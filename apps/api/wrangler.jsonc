{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "api",
	"main": "src/app.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat"],
	"send_metrics": false,
	// --- Custom domain: api.epicenter.so (auto-creates DNS record on deploy) ---
	"routes": [
		{
			"pattern": "api.epicenter.so",
			"custom_domain": true
		}
	],
	// --- Vars: non-secret config accessible via env ---
	"vars": {
		"BASE_URL": "https://api.epicenter.so",
		"GOOGLE_CLIENT_ID": "702083743841-820rm0nhf9kslmvqcikecgkmku5agbbi.apps.googleusercontent.com"
	},
	// --- KV: Session cache (Better Auth SecondaryStorage) ---
	// Create with: bunx wrangler kv namespace create "epicenter-sessions"
	"kv_namespaces": [
		{
			"binding": "SESSION_KV",
			"id": "a67bda23b98441bfa9f56c2ca2e8e1de"
		}
	],
	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "WORKSPACE_ROOM",
				"class_name": "WorkspaceRoom"
			},
			{
				"name": "DOCUMENT_ROOM",
				"class_name": "DocumentRoom"
			}
		]
	},
	// SQLite-backed DO — persistent storage survives hibernation.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["WorkspaceRoom", "DocumentRoom"]
		}
	],
	// --- Secrets (set via `wrangler secret put`, typed via `wrangler types`) ---
	"secrets": {
		"required": [
			"BETTER_AUTH_SECRET",
			// ENCRYPTION_SECRETS: Separate from BETTER_AUTH_SECRET. Used to derive per-user
			// encryption keys via HKDF. Format: "version:secret,version:secret" (e.g.
			// "2:newBase64,1:oldBase64"). Generate each secret with: openssl rand -base64 32
			"ENCRYPTION_SECRETS",
			"GOOGLE_CLIENT_SECRET",
			"OPENAI_API_KEY",
			"ANTHROPIC_API_KEY"
			// "GEMINI_API_KEY",
			// "GROK_API_KEY"
		]
	},
	// --- Hyperdrive: Postgres connection pool ---
	// Create with: bunx wrangler hyperdrive create epicenter-db --connection-string="postgres://..."
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "005e81db57f845f681cb9e27edec2809",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/epicenter"
		}
	],
	// Smart Placement: Run your Worker close to your database for lower latency
	"placement": {
		"region": "aws:us-east-2"
	}
}
